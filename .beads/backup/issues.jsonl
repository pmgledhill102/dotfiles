{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"Implemented in PR #35","closed_at":"2026-02-25T18:05:50Z","closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":null,"created_at":"2026-02-24T08:43:53Z","created_by":"Paul Gledhill","crystallizes":0,"defer_until":null,"description":"Add an interactive CLI menu during chezmoi init that asks what 'type' of machine is being provisioned (e.g. personal, work, server/minimal). On a work machine, all config should be applied but application installation should be selective — skip most Brewfile apps and VS Code extensions, but still install 'essential' software. This requires: (1) a chezmoi template prompt or init script that sets a machine_type data field, (2) conditional logic in Brewfile.tmpl to split packages into essential vs full, (3) conditional VS Code extension installation, (4) persisting the choice in .chezmoi.toml so subsequent applies respect it.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"dotfiles-pm3","is_template":0,"issue_type":"feature","last_activity":null,"metadata":"{}","mol_type":"","notes":"","original_size":null,"owner":"","payload":"","pinned":0,"priority":1,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":null,"status":"closed","target":"","timeout_ns":0,"title":"CLI menu-driven machine type selection for chezmoi init","updated_at":"2026-02-25T18:05:50Z","waiters":"","wisp_type":"","work_type":"mutex"}
{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"Fixed in fix/starship-timeout branch","closed_at":"2026-02-28T16:57:06Z","closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":null,"created_at":"2026-02-28T16:51:41Z","created_by":"Paul Gledhill","crystallizes":0,"defer_until":null,"description":"On work machine, Python and Go version checks in Starship regularly exceed the 500ms default timeout, cluttering shell output with warnings. Fix: set command_timeout = 2000 (2 seconds) in the Starship config. This applies across all machine types. The Starship config is likely at home/dot_config/starship.toml or similar chezmoi-managed path.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"dotfiles-pvt","is_template":0,"issue_type":"bug","last_activity":null,"metadata":"{}","mol_type":"","notes":"","original_size":null,"owner":"","payload":"","pinned":0,"priority":1,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":null,"status":"closed","target":"","timeout_ns":0,"title":"Fix Starship language version check timeouts","updated_at":"2026-02-28T16:57:06Z","waiters":"","wisp_type":"","work_type":"mutex"}
