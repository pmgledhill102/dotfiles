{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"Superseded by Bitwarden approach (PR #42)","closed_at":"2026-02-28T14:38:53Z","closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":null,"created_at":"2026-02-24T08:43:43Z","created_by":"Paul Gledhill","crystallizes":0,"defer_until":null,"description":"The entire secrets pipeline is designed and documented but not turned on. .chezmoi.toml has no [age] section, and dot_secrets.tmpl is a placeholder. Until this is live, API keys have to be manually managed on each machine, defeating the purpose of chezmoi. Steps: generate age key, add [age] to .chezmoi.toml, chezmoi add --encrypt ~/.secrets, update .chezmoiignore for conditional handling, document key storage in Bitwarden.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"dotfiles-7r3","is_template":0,"issue_type":"feature","last_activity":null,"metadata":"{}","mol_type":"","notes":"","original_size":null,"owner":"","payload":"","pinned":0,"priority":1,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":null,"status":"closed","target":"","timeout_ns":0,"title":"Activate age-encrypted secrets management","updated_at":"2026-02-28T14:38:53Z","waiters":"","wisp_type":"","work_type":"mutex"}
