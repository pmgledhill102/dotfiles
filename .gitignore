# Dotfiles managed by chezmoi

# Ignore local state
.chezmoi.yaml
.chezmoistate.boltdb

# Ignore secrets
.secrets

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore editor/IDE files
.vscode/
.idea/

# Project-local Claude Code settings (machine-specific permissions, never shared)
.claude/settings.local.json

# Ignore shell history
.zsh_history
.bash_history

# Ignore temporary files
temp/

# Ignore downloaded binaries at repo root (not nested bin/ dirs under home/)
/bin/

# Dolt database files (added by bd init)
.dolt/
*.db

# Beads / Dolt files (added by bd init)
.beads-credential-key

# Beads exports — source of truth is Dolt + refs/dolt/data on origin.
# The JSONL stays fresh on disk for IDE visibility but never enters commits.
.beads/issues.jsonl
